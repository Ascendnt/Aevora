#--------------------------------------------------------------------
# HRIS environment config
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

# Set this to the URL you serve the app from
app.baseURL = 'http://localhost:8080/'
app.indexPage = ''

#--------------------------------------------------------------------
# DATABASE — PostgreSQL
# Update username/password to match your local Postgres.
# Create the database first:  CREATE DATABASE hris;
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = hris
database.default.username = postgres
database.default.password = admin
database.default.DBDriver = Postgre
database.default.port = 5432
database.default.charset = utf8
